    "Logs are automatically deleted after 24 hours. Logs contain debug information for troubleshooting cursor issues." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protokolle werden nach 24 Stunden automatisch gelöscht. Die Protokolle enthalten Debug-Informationen zur Fehlerbehebung bei Cursor-Problemen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les journaux seront automatiquement supprimés après 24 heures. Les journaux contiennent des informations de débogage pour résoudre les problèmes de curseur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ログは24時間後に自動的に削除されます。ログにはカーソルの問題をトラブルシューティングするためのデバッグ情報が含まれています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로그는 24시간 후 자동으로 삭제됩니다. 로그에는 커서 문제 해결을 위한 디버그 정보가 포함되어 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
